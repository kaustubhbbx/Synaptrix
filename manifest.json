{
  "manifest_version": 3,
  "name": "Truth Layer",
  "version": "2.0.0",
  "description": "Hardened real-time AI hallucination detector for ChatGPT — multi-layer verification with cross-checking, confidence scoring, and strict grounding enforcement.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.chatgpt.com/*",
        "https://chatgpt.com/*",
        "http://*.chatgpt.com/*",
        "https://openai.com/*",
        "https://claude.ai/*",
        "https://*.claude.ai/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Truth Layer",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
